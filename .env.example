# GitHub OAuth App Credentials
# Create one at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret

# Session Cookie Encryption Key (Generar un string largo y aleatorio)
SESSION_SECRET_KEY=super_secret_key_12345

# Months of inactivity to consider a repo inactive (default: 6)
INACTIVITY_MONTHS=6

# HaveIBeenPwned API Key (opcional, para /check-leaks)
HIBP_API_KEY=your_hibp_key_here

# Google OAuth2 Credentials (para Google Drive local)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Reddit API Credentials (opcional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
